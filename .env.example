# Backend
CITYMATE_ENV=local
CITYMATE_USE_LIVE_DATA=true
CITYMATE_REQUEST_TIMEOUT=20.0
CITYMATE_MAP_PROVIDER=open
AMAP_WEB_SERVICE_KEY=
CITYMATE_LLM_PROVIDER=mock

# Optional authorized Meituan/Dianping export. JSON entries can override POI
# image_url, rating, review_count, price_per_person, address, and platform_url.
CITYMATE_VENDOR_DATA_PATH=

# Optional authorized merchant API. The backend POSTs city + candidate POIs and
# expects JSON shaped like docs/vendor-data.example.json.
CITYMATE_VENDOR_API_URL=
CITYMATE_VENDOR_API_KEY=
CITYMATE_VENDOR_API_KEY_HEADER=Authorization

# Optional OpenAI-compatible LLM settings. For local Ollama, use:
# CITYMATE_LLM_PROVIDER=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_MODEL=gemma3:12b
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Frontend
VITE_API_BASE_URL=
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors
